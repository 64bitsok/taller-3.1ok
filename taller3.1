        private void seleccion_Click(object sender, EventArgs e)
        {
            using (pubsEntities db = new pubsEntities())
            {
                var resultado = db.titles
                                  .Where(t => t.price > 20)
                                  .ToList();
                dgvDatos.DataSource = resultado;
            }
        }
